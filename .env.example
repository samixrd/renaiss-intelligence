# ─────────────────────────────────────────────────────────────────────────────
# Renaiss Glass Insight — Environment Variable Reference
#
# Copy this file to .env and fill in the real values for local development.
#   cp .env.example .env
#
# ⚠  NEVER commit the real .env file — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── Turso (libSQL) Database ───────────────────────────────────────────────────
#
# Obtain these from the Turso dashboard → your database → "Connect".
# https://app.turso.tech/

# WebSocket/HTTP URL of your Turso database.
# Format: libsql://<database-name>-<org-name>.aws-<region>.turso.io
TURSO_DATABASE_URL=libsql://your-database-name-your-org.aws-region.turso.io

# Authentication token (read-write).
# Generate one: Turso dashboard → your database → "+ Create Token"
TURSO_AUTH_TOKEN=your_turso_auth_token_here
